{
  "name": "history-clipboard",
  "version": "0.1.0",
  "description": "A local Windows clipboard history app for text and images.",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc --noEmit && electron-vite build",
    "dist": "electron-builder --win nsis"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.0.5",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  },
  "build": {
    "appId": "com.local.historyclipboard",
    "productName": "历史剪贴板",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "!**/*.map"
    ],
    "extraMetadata": {
      "author": "Jin-wen-jie"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName} Setup ${version}.${ext}",
      "unicode": true
    },
    "afterPack": "./scripts/afterPack.cjs",
    "publish": {
      "provider": "github",
      "owner": "Jin-wen-jie",
      "repo": "history-clipboard",
      "releaseType": "release"
    }
  }
}
